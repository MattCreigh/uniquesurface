# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
build/
dist/
*.egg-info/
*.egg
.eggs/
.installed.cfg
MANIFEST

# Unit test / coverage reports
.coverage
.coverage.*
coverage.xml
htmlcov/
.pytest_cache/
.cache
.mypy_cache/
.ruff_cache/

# uv
.venv/

# Environment
.env
.env.local

# Editor
.vscode/
.idea/
*.swp
*.swo

# trinity runtime state (never commit these — they're machine-specific)
*.bak
*.drift
# Pristine QML templates extracted at runtime into the per-user state dir
# (~/.local/state/trinity/templates/). Anchor to avoid matching source
# dirs like src/trinity/systemd/templates/.
/**/templates/*.qml
*.debian.tar.xz
